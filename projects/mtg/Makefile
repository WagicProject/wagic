wagic.app/Contents/PkgInfo: 
	@test -d wagic.app/Contents || mkdir -p wagic.app/Contents
	@$(DEL_FILE) wagic.app/Contents/PkgInfo
	@echo "APPL????" > wagic.app/Contents/PkgInfo
wagic.app/Contents/Resources/empty.lproj: 
	@test -d wagic.app/Contents/Resources || mkdir -p wagic.app/Contents/Resources
	@touch wagic.app/Contents/Resources/empty.lproj
	
wagic.app/Contents/Info.plist: 
	@test -d wagic.app/Contents || mkdir -p wagic.app/Contents
	@$(DEL_FILE) wagic.app/Contents/Info.plist
	@sed -e "s,@SHORT_VERSION@,1.0,g" -e "s,\$${QMAKE_SHORT_VERSION},1.0,g" -e "s,@FULL_VERSION@,1.0.0,g" -e "s,\$${QMAKE_FULL_VERSION},1.0.0,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" -e "s,@BUNDLEIDENTIFIER@,com.yourcompany.wagic,g" -e "s,\$${PRODUCT_BUNDLE_IDENTIFIER},com.yourcompany.wagic,g" -e "s,\$${MACOSX_DEPLOYMENT_TARGET},11.0,g" -e "s,\$${IPHONEOS_DEPLOYMENT_TARGET},,g" -e "s,\$${TVOS_DEPLOYMENT_TARGET},,g" -e "s,\$${WATCHOS_DEPLOYMENT_TARGET},,g" -e "s,@ICON@,wagic.icns,g" -e "s,\$${ASSETCATALOG_COMPILER_APPICON_NAME},wagic.icns,g" -e "s,@EXECUTABLE@,wagic,g" -e "s,@LIBRARY@,wagic,g" -e "s,\$${EXECUTABLE_NAME},wagic,g" -e "s,@TYPEINFO@,????,g" -e "s,\$${QMAKE_PKGINFO_TYPEINFO},????,g" MacOS/Info.plist >wagic.app/Contents/Info.plist
