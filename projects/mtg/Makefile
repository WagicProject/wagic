####### Install

install_target: first FORCE
	@test -d $(INSTALL_ROOT)/usr/bin || mkdir -p $(INSTALL_ROOT)/usr/bin
	$(DEL_FILE) -r $(INSTALL_ROOT)/usr/bin/wagic.app
	
	$(QINSTALL) wagic.app $(INSTALL_ROOT)/usr/bin/wagic.app
	-$(STRIP) $(INSTALL_ROOT)/usr/bin/wagic.app/Contents/MacOS/$(QMAKE_TARGET)

uninstall_target: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/bin/wagic.app
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/bin/ 


install_desktop: first FORCE
	@test -d $(INSTALL_ROOT)/usr/share/applications || mkdir -p $(INSTALL_ROOT)/usr/share/applications
	$(QINSTALL) /Users/michael/Documents/GitHub/protoWagic/projects/mtg/wagic.desktop $(INSTALL_ROOT)/usr/share/applications/wagic.desktop

uninstall_desktop: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/share/applications/wagic.desktop
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/share/applications/ 


install_icon: first FORCE
	@test -d $(INSTALL_ROOT)/usr/share/icons/hicolor/64x64/apps || mkdir -p $(INSTALL_ROOT)/usr/share/icons/hicolor/64x64/apps
	$(QINSTALL) /Users/michael/Documents/GitHub/protoWagic/projects/mtg/wagic-64x64.png $(INSTALL_ROOT)/usr/share/icons/hicolor/64x64/apps/wagic-64x64.png

uninstall_icon: FORCE
	-$(DEL_FILE) -r $(INSTALL_ROOT)/usr/share/icons/hicolor/64x64/apps/wagic-64x64.png
	-$(DEL_DIR) $(INSTALL_ROOT)/usr/share/icons/hicolor/64x64/apps/ 


install: install_target install_desktop install_icon  FORCE

uninstall: uninstall_target uninstall_desktop uninstall_icon  FORCE

FORCE:

